{
  "crons": [
    {
      "path": "/api/push/send",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/ai/periodic?type=weekly",
      "schedule": "0 20 * * 0"
    },
    {
      "path": "/api/ai/periodic?type=monthly",
      "schedule": "0 20 1 * *"
    },
    {
      "path": "/api/ai/periodic?type=yearly",
      "schedule": "0 20 1 1 *"
    }
  ]
}
