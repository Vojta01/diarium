# ── Supabase ──
# Your Supabase project URL (e.g. https://abc123.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon/public key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Supabase service_role key (server-side only — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── DeepSeek API (for AI reports / reflections) ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Web Push / VAPID ──
# VAPID private key — generated via web-push CLI or online tool
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# VAPID public key — shared with clients; uses built-in default if omitted
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BDQqhS8ckDCRGmoE6gfdRsoM9rGTbP9188B_Ue-XpHV3oNG9bbkG3rpLLONLwVT3D_mJFEhAjzhE2inp_hc0POY
# Contact email for push notification VAPID details
VAPID_EMAIL=mailto:your-email@example.com

# ── Upstash Redis (for push subscription storage) ──
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ── Cron / Security ──
# Secret used to authenticate Vercel Cron Jobs
CRON_SECRET=your_cron_secret_here

# ── Feature Flags ──
# Comma-separated features to enable. Options: core, personal
#   core     – standard features (default if omitted)
#   personal – personal/private features (sensitive habits tracking, etc.)
NEXT_PUBLIC_FEATURES=core
